{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=ProductsDb;User Id=sa;Password=YourStrong@Password;TrustServerCertificate=True;MultipleActiveResultSets=True"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ReverseProxy": {
    "Routes": {
      "api-route": {
        "ClusterId": "api-cluster",
        "Match": { "Path": "/api/{**catch-all}" }
      },
      "backoffice-route": {
        "ClusterId": "backoffice-cluster",
        "Match": { "Path": "/admin/{**catch-all}" }
      },
      "frontoffice-route": {
        "ClusterId": "frontoffice-cluster",
        "Match": { "Path": "{**catch-all}" }
      }
    },
    "Clusters": {
      "api-cluster": { "Destinations": { "d1": { "Address": "https://localhost:7001" } } },
      "backoffice-cluster": { "Destinations": { "d1": { "Address": "http://localhost:5174" } } },
      "frontoffice-cluster": { "Destinations": { "d1": { "Address": "http://localhost:5173" } } }
    }
  },
  "AllowedHosts": "*"
}
