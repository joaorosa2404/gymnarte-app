{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=gymnartedb;Username=postgres;Password=YourPassword"
  },
  "Jwt": {
    "Key": "GymnArteApp-SuperSecretKey-MustBeAtLeast32Chars!!",
    "Issuer": "GymnArteApp.Server",
    "Audience": "GymnArteApp.Clients",
    "ExpiresInMinutes": 480
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ReverseProxy": {
    "Routes": {
      "backoffice-route": {
        "ClusterId": "backoffice-cluster",
        "Order": 1,
        "Match": { "Path": "/admin/{**catch-all}" }
      },
      "frontoffice-route": {
        "ClusterId": "frontoffice-cluster",
        "Order": 2,
        "Match": { "Path": "{**catch-all}" }
      }
    },
    "Clusters": {
      "backoffice-cluster": {
        "Destinations": {
          "d1": { "Address": "http://localhost:5174" }
        }
      },
      "frontoffice-cluster": {
        "Destinations": {
          "d1": { "Address": "http://localhost:5173" }
        }
      }
    }
  },
  "AllowedHosts": "*"
}
