{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=ProductsDb;User Id=sa;Password=YourStrong@Password;TrustServerCertificate=True;MultipleActiveResultSets=True"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ReverseProxy": {
    "Routes": {
      "backoffice-route": {
        "ClusterId": "backoffice-cluster",
        "Order": 1,
        "Match": { "Path": "/admin/{**catch-all}" }
      },
      "frontoffice-route": {
        "ClusterId": "frontoffice-cluster",
        "Order": 2,
        "Match": { "Path": "{**catch-all}" }
      }
    },
    "Clusters": {
      "backoffice-cluster": {
        "Destinations": {
          "d1": { "Address": "http://localhost:5174" }
        }
      },
      "frontoffice-cluster": {
        "Destinations": {
          "d1": { "Address": "http://localhost:5173" }
        }
      }
    }
  },
  "AllowedHosts": "*"
}
